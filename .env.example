LOG_LEVEL=INFO
DB_PATH=data/service.db

# Optional legacy webhook settings. Not required for local scheduled runs.
WEBHOOK_VERIFY_TOKEN=replace-with-random-shared-token
ALLOWED_ATHLETE_IDS=123456

STRAVA_CLIENT_ID=12345
STRAVA_CLIENT_SECRET=replace-me
STRAVA_REFRESH_TOKEN=replace-me
STRAVA_ATHLETE_ID=123456

REQUEST_TIMEOUT_SECONDS=10
WORKER_POLL_INTERVAL_SECONDS=2
WORKER_LEASE_SECONDS=90
MAX_RETRY_ATTEMPTS=5
RETRY_BACKOFF_SECONDS=30

CONFIDENCE_THRESHOLD=0.75
OVERWRITE_MANUAL_TITLES=false
OVERWRITE_EXISTING_GENERATED_TITLES=true
DEFAULT_TITLE_ALLOWLIST=

REVERSE_GEOCODE_ENABLED=true
VIA_PLACE_SAMPLE_COUNT=6
VIA_PLACE_OUTPUT_LIMIT=8
OVERPASS_RETRY_ATTEMPTS=3
OVERPASS_RETRY_BASE_DELAY_SECONDS=1.0
OVERPASS_RETRY_MAX_DELAY_SECONDS=6.0
NOMINATIM_RETRY_ATTEMPTS=3
NOMINATIM_RETRY_BASE_DELAY_SECONDS=1.5
NOMINATIM_RETRY_MAX_DELAY_SECONDS=8.0
ROUTE_HIGHLIGHT_LIMIT=6
STRAVA_SEGMENT_CANDIDATE_LIMIT=8

GEOCODE_USER_AGENT=strava-renamer/0.1
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
OVERPASS_BASE_URL=https://overpass-api.de/api/interpreter
